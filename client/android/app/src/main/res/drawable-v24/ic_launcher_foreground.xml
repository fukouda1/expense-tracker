<?xml version="1.0" encoding="utf-8"?>
<!--
  TraceCash adaptive icon foreground
  Viewport: 108×108dp  |  Safe zone: 18–90 on each axis (72×72 centre)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Coin / circle backdrop -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.15"
        android:pathData="M54,22 a32,32,0,1,1,0,64 a32,32,0,1,1,0,-64Z"/>

    <!-- Coin ring outline -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.5"
        android:fillAlpha="0"
        android:pathData="M54,23 a31,31,0,1,1,0,62 a31,31,0,1,1,0,-62Z"/>

    <!-- Bar 1 (shortest, left) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M39,70 L39,60 a2,2,0,0,1,2,-2 L45,58 a2,2,0,0,1,2,2 L47,70 Z"/>

    <!-- Bar 2 (medium, centre) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M50,70 L50,52 a2,2,0,0,1,2,-2 L56,50 a2,2,0,0,1,2,2 L58,70 Z"/>

    <!-- Bar 3 (tallest, right) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M61,70 L61,43 a2,2,0,0,1,2,-2 L67,41 a2,2,0,0,1,2,2 L69,70 Z"/>

    <!-- Trend line over bars (thick polyline rendered as filled stroke-like path) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M43,58 L54,50 L65,41"/>

    <!-- Arrow head at top of trend -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M65,41 L73,35 L67,48 Z"/>

    <!-- Base line (floor of bars) -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:strokeAlpha="0.5"
        android:pathData="M36,70 L72,70"/>

    <!-- Peso sign bottom-right accent -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.35"
        android:pathData="M76,72 a8,8,0,1,1,0,16 a8,8,0,1,1,0,-16Z"/>
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.7"
        android:pathData="M74,75 L78,75 L78,76.5 L74,76.5 Z
