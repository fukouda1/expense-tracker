<?xml version="1.0" encoding="utf-8"?>
<!--
  TraceCash adaptive icon foreground — "finding cash" magnifying glass
  Viewport: 108×108dp  |  Safe zone: 18–90 (72×72 centre)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Magnifying glass handle (bottom-right) ── -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#00000000"
        android:strokeWidth="1"
        android:pathData="M62,62 L84,84 a6,6,0,0,1,0,8.5 a6,6,0,0,1,-8.5,0 L54,70 Z"/>

    <!-- Handle shine strip -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.35"
        android:pathData="M62,62 L80,80 a2,2,0,0,1,0,3 L60,65 Z"/>

    <!-- ── Lens outer ring ── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9"
        android:pathData="M42,42 m-28,0 a28,28,0,1,1,56,0 a28,28,0,1,1,-56,0"/>

    <!-- ── Coin inside lens ── -->
    <!-- Coin shadow layer -->
    <path
        android:fillColor="#000000"
        android:fillAlpha="0.18"
        android:pathData="M43,43 m-17,0 a17,17,0,1,1,34,0 a17,17,0,1,1,-34,0"/>

