{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/tsx/dist/cli.mjs", "watch", "src/server.ts"],
      "cwd": "server",
      "port": 3001,
      "autoPort": false
    },
    {
      "name": "client",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5174"],
      "cwd": "client",
      "port": 5174
    }
  ]
}
