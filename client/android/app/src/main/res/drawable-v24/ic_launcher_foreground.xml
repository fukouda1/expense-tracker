        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="30" android:startY="30"
                android:endX="55"   android:endY="55">
                <item android:offset="0" android:color="#FBBF24"/>
                <item android:offset="1" android:color="#D97706"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Coin inner ring -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.2"
        android:fillAlpha="0"
        android:strokeAlpha="0.35"
        android:pathData="M42,42 m-13,0 a13,13,0,1,1,26,0 a13,13,0,1,1,-26,0"/>

    <!-- ₱ sign — rendered as two horizontal bars + vertical stroke -->
    <!-- Vertical stroke -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M41,30 L43,30 L43,56 L41,56 Z"/>
    <!-- Top horizontal bar -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M36,35 L48,35 L48,37 L36,37 Z"/>
    <!-- Second horizontal bar -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M36,39.5 L48,39.5 L48,41.5 L36,41.5 Z"/>
    <!-- Curved top of P -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M43,30 a9,9,0,0,1,0,13 L43,30 Z"/>

    <!-- Coin glare spot -->
    <path
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.4"
        android:pathData="M31,33 a7,4,0,0,1,8,-3 a7,4,0,0,1,-8,3 Z"/>

    <!-- ── Lens glass glare arc ── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeAlpha="0.3"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:pathData="M22,34 a24,24,0,0,1,18,-10"/>

